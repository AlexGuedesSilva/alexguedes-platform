# =========================
# REDIS
# =========================
REDIS_HOST=redis
REDIS_PORT=6379

# =========================
# POSTGRES
# =========================
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/authdb_v1
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# =========================
# JWT
# =========================
JWT_SECRET=change-me-to-a-long-secret
JWT_EXPIRES_IN_SECONDS=3600
REFRESH_TOKEN_EXPIRES_IN_SECONDS=604800

# =========================
# HMAC
# =========================
HMAC_CLIENT_KEY=demo-key
HMAC_CLIENT_SECRET=change-me
HMAC_ALLOWED_SKEW=PT5M
HMAC_NONCE_TTL=PT10M

# =========================
# INTERNAL SERVICES
# =========================
VALIDATE_SERVICE_URL=http://validate-service:8081
AUTH_SERVICE_V1_URL=http://auth-service:8082
AUTH_SERVICE_V2_URL=http://auth-service-v2:8085
SIGNER_SERVICE_URL=http://signer-service:8083
